{
  "name": "certificate-generator-server",
  "version": "1.0.0",
  "description": "Digital Certificate Generation & Verification System - Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --watch -r ts-node/register src/server.ts",
    "build": "tsc && copyfiles -u 1 src/script/init.script.sql dist/",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "copyfiles": "^2.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
